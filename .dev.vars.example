# Copy this file to .dev.vars for local Cloudflare/OpenNext preview.
# These entries are server-side runtime vars only. Client-side Firebase vars
# (`NEXT_PUBLIC_FIREBASE_*`) are configured separately (see `lib/firebase/config.ts`)
# via local `.env` and/or your build/deploy environment variable settings.
NEXTJS_ENV=development
TMDB_BEARER_TOKEN=
TMDB_API_KEY=
TRAKT_CLIENT_ID=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

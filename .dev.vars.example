# Copy this file to .dev.vars for local Cloudflare/OpenNext preview.
# These entries are server-side runtime vars only. Non-secret deploy vars,
# including the `NEXT_PUBLIC_FIREBASE_*` values, are generated separately into
# `.wrangler/wrangler.local.jsonc` from local `.env`.
NEXTJS_ENV=development
TMDB_BEARER_TOKEN=
TMDB_API_KEY=
TRAKT_CLIENT_ID=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
TURNSTILE_SECRET_KEY=
